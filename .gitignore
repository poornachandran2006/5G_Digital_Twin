# ========================
# Python Core
# ========================
__pycache__/
*.py[cod]
*$py.class
*.so

# ========================
# Virtual Environments
# ========================
venv/
env/
ENV/
.venv/

# ========================
# Environment Variables
# ========================
.env
.env.local

# ========================
# Data Files
# Keep essential datasets (e.g., CSV)
# Ignore databases and heavy local storage
# ========================
data/*.db
data/*.sqlite
data/*.sqlite3

# ========================
# Model Files
# Keep lightweight inference artifacts (e.g., scaler.pkl, json models)
# Ignore heavy training artifacts
# ========================
models/*.pt
models/*.pth
models/*.h5
models/*.zip

# ========================
# Logs & Experiment Outputs
# ========================
logs/
*.log
runs/
ppo_tensorboard/

# ========================
# Testing & Coverage
# ========================
.pytest_cache/
.coverage
htmlcov/
*.cover

# ========================
# Frontend (React / Vite)
# ========================
node_modules/
frontend/node_modules/
frontend/dist/

# ========================
# Build / Distribution
# ========================
build/
dist/
*.egg-info/
.eggs/

# ========================
# IDE / Editor
# ========================
.vscode/
.idea/
*.swp
*.swo
*~

# ========================
# OS Files
# ========================
.DS_Store
Thumbs.db

# ========================
# Temporary / Output Files
# ========================
test_*.txt

# ========================
# Debug / Verification Scripts
# ========================
verify_*.py
scripts/verify_*.py

# ========================
# Optional (uncomment if needed)
# ========================
# models/*.pkl     # ONLY if you decide to exclude scaler.pkl later
# data/*.csv       # ONLY if dataset becomes too large